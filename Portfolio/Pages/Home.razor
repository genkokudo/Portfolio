@page "/"
@using Portfolio.Components.Home
@using Portfolio.Components.Works
@using Portfolio.Pages.Components
@using Portfolio.Shared.Model

<PageTitle>@PageTitleText</PageTitle>

<HeroSection />

<section id="about" class="content-placeholder" aria-labelledby="content-status">
    <h2 id="content-status">@message</h2>
    <Skills Items="PortfolioData?.Skills" />
    <WorkHistories Items="PortfolioData?.WorkHistories" />
</section>

<WorksSection Items="PortfolioData?.Works" />

@code {
    [CascadingParameter]
    private PortfolioData? PortfolioData { get; set; }

    private string message => PortfolioData is null ? "読み込み中..." : "Portfolio Data";
    private string PageTitleText => $"{PortfolioData?.AuthorNameAlphabet ?? "Portfolio"} | Software Engineer";
}
