@using Portfolio.Shared.Model

<section class="work-category" aria-label="@CategoryName">
    <h3>@CategoryName</h3>

    <div class="carousel-shell">
        <MudCarousel TData="IReadOnlyList<WorkItem>"
                     ItemsSource="@Pages"
                     Class="works-carousel"
                     Style="@CarouselStyle"
                     ShowArrows="@HasMultiplePages"
                     ShowBullets="@HasMultiplePages"
                     ArrowsColor="Color.Primary"
                     BulletsColor="Color.Primary"
                     EnableSwipeGesture="true"
                     AutoCycle="false">
            <ItemTemplate Context="page">
                <div class="works-page @(HasMultiplePages ? "works-page--with-navigation" : "works-page--without-navigation")">
                    @foreach (var work in page)
                    {
                        <WorkCard Work="@work" />
                    }
                </div>
            </ItemTemplate>
        </MudCarousel>
    </div>
</section>

@code {
    private const int PageSize = 4;

    [Parameter, EditorRequired]
    public string CategoryName { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public IReadOnlyList<WorkItem> Items { get; set; } = [];

    private IReadOnlyList<IReadOnlyList<WorkItem>> Pages { get; set; } = [];
    private bool HasMultiplePages => Pages.Count > 1;
    private WorkCategory Category => Items.FirstOrDefault()?.Category ?? WorkCategory.Unknown;
    private string CarouselStyle => $"height: {CarouselHeight}px;";

    private int CarouselHeight => (Category, HasMultiplePages) switch
    {
        (WorkCategory.Flyer, true) => 580,
        (WorkCategory.Flyer, false) => 532,
        (_, true) => 460,
        (_, false) => 415
    };

    protected override void OnParametersSet()
    {
        Pages = Items
            .Chunk(PageSize)
            .Select(page => (IReadOnlyList<WorkItem>)page)
            .ToList();
    }
}
